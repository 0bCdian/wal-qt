{
  "name": "wal-qt-renderer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint . --config .oxlintrc.json --tsconfig tsconfig.json",
    "lint:advisory": "pnpm run lint || true",
    "format": "oxfmt --config .oxfmtrc.json --write .",
    "format:check": "oxfmt --config .oxfmtrc.json --check .",
    "format:check:advisory": "pnpm run format:check || true",
    "check:all": "pnpm run lint:advisory && pnpm run format:check:advisory && pnpm run typecheck && pnpm run test",
    "check:all:strict": "pnpm run lint && pnpm run format:check && pnpm run typecheck && pnpm run test",
    "test": "vitest run",
    "preview": "vite preview"
  },
  "dependencies": {
    "gsap": "^3.14.2"
  },
  "devDependencies": {
    "jsdom": "^26.1.0",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.50.0",
    "typescript": "~5.6.2",
    "vite": "^6.4.2",
    "vitest": "^4.1.4"
  },
  "packageManager": "pnpm@11.1.1"
}
